# Server
PORT=3000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/bubble_db

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_ACCESS_SECRET=replace_with_long_random_secret_access
JWT_REFRESH_SECRET=replace_with_long_random_secret_refresh
PHONE_HMAC_SECRET=replace_with_long_random_secret_phone

# Admin
ADMIN_SECRET=replace_with_long_random_secret_admin

# OTP
OTP_EXPIRY_SECONDS=600

# Storage — base URL used when building media URLs returned to clients
STORAGE_BASE_URL=http://localhost:3000

# Firebase Admin SDK (Phase 1 — Firebase Phone Auth)
# FIREBASE_PROJECT_ID: your Firebase project ID (e.g. bubble-dev-12345)
FIREBASE_PROJECT_ID=

# FIREBASE_SERVICE_ACCOUNT: either a JSON string of the service account key,
# or an absolute path to the service account JSON file on disk.
# On Cloud Run, leave blank and use Application Default Credentials instead.
FIREBASE_SERVICE_ACCOUNT=
