# Copy this file to .env and fill in the values.
# Never commit the real .env to git.

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# Public URL of this server (used for self-referential links, CORS hints, etc.)
# Local dev:   http://localhost:3000
# Production:  https://your-production-server.com
PUBLIC_URL=http://localhost:3000

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/bubble_db

# ── Auth ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=replace_with_long_random_secret_access
JWT_REFRESH_SECRET=replace_with_long_random_secret_refresh

# ── Admin ──────────────────────────────────────────────────────────────────────
ADMIN_SECRET=replace_with_long_random_secret_admin

# ── Firebase Admin SDK — required ─────────────────────────────────────────────
# FIREBASE_PROJECT_ID: your Firebase project ID (e.g. bubble-mvp-12345)
FIREBASE_PROJECT_ID=bubble-mvp-12345

# FIREBASE_SERVICE_ACCOUNT: JSON string of the service account key,
# or absolute path to the service account JSON file on disk.
# On Cloud Run / GCP, leave blank — Application Default Credentials are used automatically.
FIREBASE_SERVICE_ACCOUNT=

# Firebase Storage bucket name (e.g. your-project.appspot.com)
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
