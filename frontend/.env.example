# Copy this file to .env and fill in the values for your environment.
# Expo inlines EXPO_PUBLIC_* variables at bundle time (SDK 49+).
# After changing .env, restart Metro: npx expo start --clear

# ── API URL ────────────────────────────────────────────────────────────────────
# Pick ONE of the three options below and uncomment it.

# Option 1 — Production (remote server, accessible from any internet connection)
# EXPO_PUBLIC_API_URL=https://your-production-server.com/api/v1

# Option 2 — Local Wi-Fi (physical device on the same network as your dev machine)
# Replace with your machine's LAN IP (run `ipconfig` on Windows or `ifconfig` on Mac)
# EXPO_PUBLIC_API_URL=http://192.168.1.x:3000/api/v1

# Option 3 — Android emulator (emulator cannot reach LAN IPs; 10.0.2.2 maps to host machine)
# EXPO_PUBLIC_API_URL=http://10.0.2.2:3000/api/v1

# Active value (change this to match your environment):
EXPO_PUBLIC_API_URL=http://localhost:3000/api/v1

# ── Firebase Auth — REQUIRED ───────────────────────────────────────────────────
# Get these from Firebase console → Project Settings → Your apps → Web app config.
EXPO_PUBLIC_FIREBASE_API_KEY=your_api_key_here
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
EXPO_PUBLIC_FIREBASE_APP_ID=your_app_id
