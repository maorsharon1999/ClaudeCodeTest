{
  "expo": {
    "name": "Bubble",
    "slug": "bubble",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#6C47FF"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.bubble.mvp",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Bubble uses your photos for your profile.",
        "NSMicrophoneUsageDescription": "Bubble uses your microphone to record voice notes."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#6C47FF"
      },
      "package": "com.bubble.mvp",
      "permissions": ["RECORD_AUDIO"],
      "config": { "googleMaps": { "apiKey": "PLACEHOLDER_REPLACE_ME" } }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      ["expo-secure-store"],
      ["expo-location", {
        "locationWhenInUsePermission": "Bubble needs your location to find people nearby."
      }],
      ["react-native-maps"]
    ]
  }
}
