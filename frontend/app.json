{
  "expo": {
    "name": "Bubble",
    "slug": "bubble",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#6C47FF"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.bubble.mvp",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Bubble uses your photos for your profile.",
        "NSMicrophoneUsageDescription": "Bubble uses your microphone to record voice notes."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.bubble.mvp",
      "permissions": [
        "RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCZ61NHglKjwsHS7tqpVZ0Ebt4HiPQNIAA"
        }
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "resizeMode": "contain",
          "backgroundColor": "#6C47FF"
        }
      ],
      [
        "expo-secure-store"
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Bubble needs your location to find people nearby."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "332fc6e1-0521-436d-8b8c-1c507861ad36"
      }
    },
    "owner": "maorsharon"
  }
}
